{
	"devDependencies": {
		"@playwright/test": "^1.40.0",
		"@types/jest": "^30.0.0",
		"@types/js-yaml": "^4.0.5",
		"@types/jsdom": "^21.1.7",
		"@types/node": "^24.0.10",
		"@types/sinon": "^17.0.4",
		"electron": "^37.2.0",
		"jest": "^30.0.4",
		"jest-environment-jsdom": "^30.0.4",
		"js-yaml": "^4.1.0",
		"jsdom": "^26.1.0",
		"sinon": "^21.0.0",
		"tailwindcss": "^4.1.11",
		"ts-jest": "^29.4.0",
		"typescript": "^5.8.3"
	},
	"scripts": {
		"test": "jest",
		"test:unit": "jest packages/adapters packages/core packages/cli --testPathIgnorePatterns=integration",
		"test:integration": "jest packages/integration",
		"test:contract": "jest contract",
		"test:e2e": "playwright test",
		"test:all": "npm run test:unit && npm run test:integration && npm run test:contract",
		"build": "tsc && npm run copy-renderer",
		"copy-renderer": "copy packages\\electron\\renderer\\*.js dist\\packages\\electron\\renderer\\ && copy packages\\electron\\renderer\\*.html dist\\packages\\electron\\renderer\\",
		"electron": "electron dist/packages/electron/main/main.js",
		"start": "npm run build && npm run electron",
		"dev": "tsc --watch",
		"cli": "node dist/packages/cli/software-manager.js"
	},
	"keywords": [],
	"author": "",
	"license": "ISC"
}